                    </Style>
                    <Style Selector="ctxt|CHyperlink:pointerover">
                        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
                    </Style>
                    <!-- Table -->
                    <Style Selector="Border.Table">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                    </Style>
                    <Style Selector="Border.TableHeader">
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                    </Style>
                    <Style Selector="Border.OddTableRow">
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                    </Style>
                    <Style Selector="Border.EvenTableRow">
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="Background" Value="#f5f5f9"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                    </Style>
                    <!-- Inline code -->
                    <Style Selector="ctxt|CCode">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding" Value="4,0,4,0"/>
                        <Setter Property="MonospaceFontFamily" Value="Consolas"/>
                        <Setter Property="Foreground" Value="DarkBlue"/>
                        <Setter Property="Background" Value="#f5f5f9"/>
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                    <!-- Code block -->
                    <Style Selector="Border.CodeBlock">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Background" Value="#f5f5f9"/>
                    </Style>
                    <Style Selector="TextBlock.CodeBlock">
                        <Setter Property="Foreground" Value="DarkBlue"/>
                        <Setter Property="FontFamily" Value="Consolas"/>
                    </Style>
                    <Style Selector="avedit|TextEditor">
                        <Setter Property="Foreground" Value="DarkBlue"/>
                        <Setter Property="FontFamily" Value="Consolas"/>
                    </Style>
                    <!-- List -->
                    <Style Selector="Grid.List">
                        <Setter Property="Margin" Value="15,0,0,0"/>
                    </Style>
</Styles>
