<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Adeptus.ViewModels"
             x:DataType="vm:TablePageViewModel"
             x:Class="Adeptus.Views.TablePageView">

    <Design.DataContext>
        <vm:DesignTablePageViewModel/>
    </Design.DataContext>

    <DataGrid ItemsSource="{Binding Issues}"
              SelectedItem="{Binding SelectedIssue}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="All"
              Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
            <DataGridTextColumn Header="Summary" Binding="{Binding Title}" Width="*"/>
            <DataGridCheckBoxColumn Header="Done" Binding="{Binding Done}" Width="Auto"/>
            <DataGridTextColumn Header="Updated" Binding="{Binding Updated}" Width="Auto"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
